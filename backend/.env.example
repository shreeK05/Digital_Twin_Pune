# ─────────────────────────────────────────────────────────────────────────────
# Pune Urban Shield — Backend Environment Variables
# Copy this file to `.env` and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ─── MongoDB Atlas ─────────────────────────────────────────────────────────
# Get from: cloud.mongodb.com → Connect → Drivers → Copy connection string
# Free M0 tier: 512MB — more than enough for this project
MONGO_URI=mongodb+srv://Shree1510:Shree1510@cluster0.ohalz2q.mongodb.net/?appName=Cluster0

# ─── Cloudinary (Photo Storage for Citizen Reports) ────────────────────────
# Get from: cloudinary.com → Dashboard → Copy API credentials
# Free tier: 25GB storage, 25GB bandwidth/month
CLOUDINARY_CLOUD_NAME=dq7qxlt1q
CLOUDINARY_API_KEY=473464496191825
CLOUDINARY_API_SECRET=LFnSe2eCSplZhUBOjrip4-TIC-s

# ─── App Config ────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# ─── Open-Meteo (NO KEY NEEDED — free public API) ──────────────────────────
# This works out of the box. No key required.
# Docs: https://open-meteo.com/en/docs

# ─── Notes ──────────────────────────────────────────────────────────────────
# MONGO_URI    → Required for persistent storage. Without it, data is in-memory
#                and lost on restart.
# Cloudinary   → Required for citizen photo uploads. Without it, report text
#                is saved but no photo is stored.
# Open-Meteo   → Always works. No key. Real weather data for Pune from WMO.
